rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Post cover images ───────────────────────────────────────────────────────
    // Anyone can read; only authenticated users can upload/delete.
    match /posts/{imageFile} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // 10 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Gallery images ──────────────────────────────────────────────────────────
    // Anyone can read; only authenticated users can upload/delete.
    match /gallery/{imageFile} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // 10 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Site-wide images (heroes, about, cta, etc.) ─────────────────────────────
    // Anyone can read; only authenticated users can upload/overwrite.
    match /site/{imageFile} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
