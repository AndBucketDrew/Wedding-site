rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Posts ──────────────────────────────────────────────────────────────────
    // Anyone can read published posts; only authenticated users can write.
    // In a real system, restrict writes further with custom claims for "admin" role.
    match /posts/{postId} {
      allow read: if resource.data.status == 'published'
                  || request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // ── Default: deny everything else ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
