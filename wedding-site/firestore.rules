rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Posts ──────────────────────────────────────────────────────────────────
    // Anyone can read published posts; only authenticated users can write.
    match /posts/{postId} {
      allow read: if resource.data.status == 'published'
                  || request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // ── Gallery ────────────────────────────────────────────────────────────────
    // Anyone can read (displayed on the public home page).
    // Only authenticated users can add, update or delete images.
    match /gallery/{imageId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ── Testimonials ───────────────────────────────────────────────────────────
    // Anyone can read (displayed on the public home page).
    // Only authenticated users can add, update or delete testimonials.
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // ── Site settings (hero/section images) ───────────────────────────────────
    // Anyone can read (needed by public pages).
    // Only authenticated users can update image URLs.
    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Default: deny everything else ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
